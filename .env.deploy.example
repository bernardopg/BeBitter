# SSH deploy configuration
# Copy to .env.deploy and fill with your local values.
# Never commit real credentials or production paths in this file.

DEPLOY_SSH_HOST=your-server-or-ip
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=your-ssh-user
DEPLOY_SSH_KEY_PATH=/home/your-user/.ssh/your-private-key
DEPLOY_REMOTE_DIR=/home/your-user/domains/your-domain.example/public_html
DEPLOY_SITE_URL=https://your-domain.example
