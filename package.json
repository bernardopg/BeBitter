{
  "name": "be-bitter-be-better",
  "homepage": "https://bebitterbebetter.com.br",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy:hostinger": "tsx scripts/deploy.ts",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build && pnpm analyze:bundle",
    "analyze:bundle": "npx vite-bundle-analyzer dist",
    "preview": "vite preview",
    "preview:network": "vite preview --host",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm test:run && pnpm build",
    "security:audit": "pnpm audit --audit-level high",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "sitemap:gen": "tsx scripts/generate-sitemap.ts",
    "feed:gen": "tsx scripts/generate-feed.ts",
    "og:gen": "tsx scripts/generate-og-images.ts",
    "route-html:gen": "tsx scripts/generate-route-html.ts",
    "indexnow:ping": "tsx scripts/indexnow-ping.ts",
    "lighthouse:budget": "tsx scripts/lighthouse-budget.ts",
    "postbuild": "pnpm route-html:gen",
    "prebuild": "pnpm sitemap:gen && pnpm feed:gen && pnpm og:gen",
    "github:harden": "./scripts/harden-github-repo.sh",
    "performance:audit": "echo 'Run lighthouse audit on your deployed site for performance metrics'",
    "optimize:images": "tsx scripts/optimize-images.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "~10.0.1",
    "react-dom": "^19.2.7",
    "react-floating-whatsapp": "^5.0.8",
    "react-hook-form": "^7.81.0",
    "react-intersection-observer": "^10.0.3",
    "react-resizable-panels": "^4.12.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/plugin-kit": "^0.7.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "beasties": "^0.4.2",
    "chrome-launcher": "^1.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5.16",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^4.1.9"
  }
}
