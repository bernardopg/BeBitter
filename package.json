{
  "name": "be-bitter-be-better",
  "homepage": "https://bebitterbebetter.com.br",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy:hostinger": "tsx scripts/deploy.ts",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build && pnpm analyze:bundle",
    "analyze:bundle": "npx vite-bundle-analyzer dist",
    "preview": "vite preview",
    "preview:network": "vite preview --host",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ci:check": "pnpm lint && pnpm test:run && pnpm build",
    "security:audit": "pnpm audit --audit-level high",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "sitemap:gen": "tsx scripts/generate-sitemap.ts",
    "route-html:gen": "tsx scripts/generate-route-html.ts",
    "postbuild": "pnpm route-html:gen",
    "prebuild": "pnpm sitemap:gen",
    "github:harden": "./scripts/harden-github-repo.sh",
    "performance:audit": "echo 'Run lighthouse audit on your deployed site for performance metrics'",
    "optimize:images": "tsx scripts/optimize-images.ts"
  },
